<Window x:Class="Part3_POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Part3_POE"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Example"
        Height="450"
        Width="800"
        Background="#1E1E2E">

    <Border CornerRadius="15"
            Padding="15"
            Margin="10">

        <!-- Main Gradient Background -->
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#3A0CA3" Offset="0"/>
                <GradientStop Color="#4361EE" Offset="0.5"/>
                <GradientStop Color="#4CC9F0" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              Opacity="0.4"
                              ShadowDepth="4"/>
        </Border.Effect>

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,15">

                <TextBlock Text="💬 ChatBot"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"/>

                <Button x:Name="CloseButton"
                        Content="Game"
                        Width="30"
                        Height="30"
                        HorizontalAlignment="Right"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand" Click="CloseButton_Click">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#06D6A0" Offset="0"/>
                            <GradientStop Color="#118AB2" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </Grid>

            <!-- Chat Area -->
            <Border Grid.Row="1"
                    Background="#22FFFFFF"
                    CornerRadius="10"
                    Padding="10">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel x:Name="chatPanel"/>

                </ScrollViewer>
            </Border>

            <!-- Input Area -->
            <Border Grid.Row="2"
                    Margin="0,15,0,0"
                    CornerRadius="12"
                    Padding="10">

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#11998E" Offset="0"/>
                        <GradientStop Color="#38EF7D" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>

                    <TextBox x:Name="User_Input"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="14"
                             Text="Send a message..."
                             VerticalAlignment="Center"/>

                    <Button Content="➤"
                            Width="40"
                            Height="40"
                            HorizontalAlignment="Right"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand" x:Name="Button1" Click="Button1_Click">

                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00C6FF" Offset="0"/>
                                <GradientStop Color="#0072FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>

                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>